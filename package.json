{
  "name": "claude-ir-automation",
  "version": "1.0.0",
  "description": "Playwright TypeScript automation framework for CareEdge IR system",
  "main": "index.js",
  "scripts": {
    "test": "npm run clean && playwright test",
    "test:counterparty": "npm run clean && playwright test tests/counterparty.spec.ts",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report:html": "playwright show-report reports/html",
    "report:allure:generate": "allure generate allure-results --clean -o allure-report",
    "report:allure:open": "allure open allure-report",
    "report:allure": "npm run report:allure:generate && npm run report:allure:open",
    "clean": "rimraf allure-results allure-report reports test-results",
    "test:fresh": "npm run clean && playwright test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.7.1",
    "dotenv": "^17.4.2",
    "rimraf": "^6.1.3"
  }
}
